# EditorConfig is awesome: https://EditorConfig.org

# Top-most EditorConfig file
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

# Markdown and YAML allow longer lines
[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.{yml,yaml}]
indent_size = 2

# Python (FastAPI, Alembic, scripts)
[*.py]
indent_size = 4
max_line_length = 100

# TypeScript / JavaScript
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2
max_line_length = 100

# JSON (package.json, tsconfig.json, etc.)
[*.json]
indent_size = 2

# Docker, Shell, Makefile, TOML
[{Dockerfile,*.dockerfile,*.sh,Makefile,*.toml}]
indent_size = 2

# HTML, CSS
[*.{html,css}]
indent_size = 2
