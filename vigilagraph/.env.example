# ──────────────────────────────────────────────────────────────────
# VigilaGraph IA — Environment Variables
# ──────────────────────────────────────────────────────────────────
# 1. Copy to .env:  cp .env.example .env
# 2. Fill in your secrets (marked with CHANGE-ME)
# 3. Deploy:  docker compose -f infra/docker-compose.prod.yml up -d
# ──────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────
ENV=production
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
PORT=80

# ── Database (PostgreSQL) ────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://vigilagraph:CHANGE-ME@postgres:5432/vigilagraph
DATABASE_URL_SYNC=postgresql+psycopg2://vigilagraph:CHANGE-ME@postgres:5432/vigilagraph
POSTGRES_USER=vigilagraph
POSTGRES_PASSWORD=CHANGE-ME
POSTGRES_DB=vigilagraph

# ── Authentication ────────────────────────────────────────────────
JWT_SECRET=CHANGE-ME

# ── AI Providers ─────────────────────────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Frontend ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── External API Keys ────────────────────────────────────────────
SEMANTIC_SCHOLAR_API_KEY=
LENS_API_TOKEN=

# ── Storage (S3-compatible) ──────────────────────────────────────
# Leave blank to use local filesystem (STORAGE_LOCAL_PATH)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=vigilagraph-storage
S3_REGION=us-east-1

# ── Local Storage Fallback ───────────────────────────────────────
STORAGE_LOCAL_PATH=/data/storage

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
