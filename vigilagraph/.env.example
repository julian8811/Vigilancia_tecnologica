# ──────────────────────────────────────────────────────────────────
# VigilaGraph IA — Environment Variables
# ──────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────
ENV=development
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ── Database (PostgreSQL) ────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://vigilagraph:vigilagraph@localhost:5432/vigilagraph
DATABASE_URL_SYNC=postgresql+psycopg2://vigilagraph:vigilagraph@localhost:5432/vigilagraph

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth / Security ──────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440  # 24 hours

# ── OpenAI / AI ──────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Object Storage (MinIO) ───────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=vigilagraph-storage
S3_REGION=us-east-1

# ── Graphify CLI ─────────────────────────────────────────────────
GRAPHIFY_COMMAND=graphify

# ── Celery ───────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
