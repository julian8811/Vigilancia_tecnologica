# ──────────────────────────────────────────────────────────────────
# VigilaGraph IA — Environment Variables
# ──────────────────────────────────────────────────────────────────
# 1. Copy to .env:  cp .env.example .env
# 2. Fill in your secrets (marked with CHANGE-ME)
# 3. Deploy:  docker compose -f infra/docker-compose.prod.yml up -d
# ──────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────
ENV=production
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
PORT=80

# ── Database (PostgreSQL) ────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://vigilagraph:CHANGE-ME@postgres:5432/vigilagraph
DATABASE_URL_SYNC=postgresql+psycopg2://vigilagraph:CHANGE-ME@postgres:5432/vigilagraph
POSTGRES_USER=vigilagraph
POSTGRES_PASSWORD=CHANGE-ME
POSTGRES_DB=vigilagraph

CELERY_RESULT_SERIALIZER=json

# ── Frontend ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
